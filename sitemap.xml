  {% assign pages = site.pages | where_exp: "item", "item.url" %}
  {% for page in pages %}
    {% assign skip = false %}
    {% if page.url contains '/assets/' %}
      {% assign skip = true %}
    {% endif %}
    {% if page.url == "/sitemap.xml" or page.url == "/robots.txt" or page.url == "/feed.xml" or page.url == "/404.html" %}
      {% assign skip = true %}
    {% endif %}
    {% unless skip %}
  <url>
    <loc>{{ page.url | absolute_url | replace: 'index.html','' }}</loc>
    {% assign lastmod = page.last_modified_at | default: page.date | default: site.time %}
    <lastmod>{{ lastmod | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>{% if page.url == "/" %}1.0{% elsif page.url == "/blog/" %}0.8{% else %}0.7{% endif %}</priority>
  </url>
    {% endunless %}
  {% endfor %}

  {% for post in site.posts %}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  {% endfor %}
